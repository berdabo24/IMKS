<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
   xmlns:logistics="http://example.org/logistics#"
   xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
   xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
>
  <rdf:Description rdf:about="http://example.org/logistics#vehicleName">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>vehicle name</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/logistics#TransportVehicle"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/logistics#StockItem">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Stock Item</rdfs:label>
    <rdfs:comment>A product or inventory item stored in warehouses.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://example.org/logistics#Entity"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/logistics#Item_FrozenFish">
    <rdf:type rdf:resource="http://example.org/logistics#Entity"/>
    <rdf:type rdf:resource="http://example.org/logistics#PerishableItem"/>
    <rdf:type rdf:resource="http://example.org/logistics#StockItem"/>
    <logistics:assignedTo rdf:resource="http://example.org/logistics#Truck_Standard"/>
    <logistics:hasAlert rdf:resource="http://example.org/logistics#Item_FrozenFish_StorageCoolingAlert"/>
    <logistics:hasAlert rdf:resource="http://example.org/logistics#Item_FrozenFish_TransportCoolingAlert"/>
    <logistics:isHazardous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</logistics:isHazardous>
    <logistics:itemName>Frozen Salmon Filets</logistics:itemName>
    <logistics:managedBy rdf:resource="http://example.org/logistics#Officer_Alice"/>
    <logistics:minThreshold rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">50</logistics:minThreshold>
    <logistics:quantity rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">120</logistics:quantity>
    <logistics:requiresCooling rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</logistics:requiresCooling>
    <logistics:storedIn rdf:resource="http://example.org/logistics#Warehouse_A"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/logistics#requiresCooling">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>requires cooling</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/logistics#StockItem"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/logistics#isHazardous">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>is hazardous</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/logistics#StockItem"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/logistics#HazMat_Depot">
    <rdf:type rdf:resource="http://example.org/logistics#Entity"/>
    <rdf:type rdf:resource="http://example.org/logistics#HazardousStorage"/>
    <rdf:type rdf:resource="http://example.org/logistics#StorageFacility"/>
    <logistics:capacity rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">300</logistics:capacity>
    <logistics:facilityName>Secured Chemical Depot</logistics:facilityName>
    <logistics:hasCooling rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</logistics:hasCooling>
    <logistics:isHazardousApproved rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</logistics:isHazardousApproved>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/logistics#Item_SulfuricAcid_StorageHazardAlert">
    <rdf:type rdf:resource="http://example.org/logistics#StorageConflictAlert"/>
    <logistics:alertMessage rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hazardous item 'Industrial Sulfuric Acid' is stored in 'Main Warehouse A', which is not approved for hazardous materials.</logistics:alertMessage>
    <logistics:alertSeverity rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Critical</logistics:alertSeverity>
    <logistics:alertType rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hazardous Storage Conflict</logistics:alertType>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/logistics#Item_CardboardBoxes">
    <rdf:type rdf:resource="http://example.org/logistics#Entity"/>
    <rdf:type rdf:resource="http://example.org/logistics#StandardItem"/>
    <rdf:type rdf:resource="http://example.org/logistics#StockItem"/>
    <logistics:assignedTo rdf:resource="http://example.org/logistics#Truck_Standard"/>
    <logistics:isHazardous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</logistics:isHazardous>
    <logistics:itemName>Cardboard Packing Boxes</logistics:itemName>
    <logistics:managedBy rdf:resource="http://example.org/logistics#Officer_Alice"/>
    <logistics:minThreshold rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">200</logistics:minThreshold>
    <logistics:quantity rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">950</logistics:quantity>
    <logistics:requiresCooling rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</logistics:requiresCooling>
    <logistics:storedIn rdf:resource="http://example.org/logistics#Warehouse_A"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/logistics#StandardItem">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Standard Item</rdfs:label>
    <rdfs:comment>Regular stock item requiring no specialized conditions.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://example.org/logistics#StockItem"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/logistics#Officer_Alice">
    <rdf:type rdf:resource="http://example.org/logistics#Entity"/>
    <rdf:type rdf:resource="http://example.org/logistics#ProcurementOfficer"/>
    <logistics:officerName>Alice Johnson</logistics:officerName>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/logistics#ProcurementOfficer">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Procurement Officer</rdfs:label>
    <rdfs:comment>Personnel responsible for managing stock inventory and alerts.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://example.org/logistics#Entity"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/logistics#ColdHub_1">
    <rdf:type rdf:resource="http://example.org/logistics#ColdStorage"/>
    <rdf:type rdf:resource="http://example.org/logistics#Entity"/>
    <rdf:type rdf:resource="http://example.org/logistics#StorageFacility"/>
    <logistics:capacity rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">500</logistics:capacity>
    <logistics:facilityName>Refrigerated ColdHub 1</logistics:facilityName>
    <logistics:hasCooling rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</logistics:hasCooling>
    <logistics:isHazardousApproved rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</logistics:isHazardousApproved>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/logistics#GeneralStorage">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>General Storage Facility</rdfs:label>
    <rdfs:comment>Standard ambient warehouse.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://example.org/logistics#StorageFacility"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/logistics#Item_SulfuricAcid">
    <rdf:type rdf:resource="http://example.org/logistics#Entity"/>
    <rdf:type rdf:resource="http://example.org/logistics#HazardousItem"/>
    <rdf:type rdf:resource="http://example.org/logistics#StockItem"/>
    <logistics:assignedTo rdf:resource="http://example.org/logistics#Truck_Standard"/>
    <logistics:hasAlert rdf:resource="http://example.org/logistics#Item_SulfuricAcid_StorageHazardAlert"/>
    <logistics:hasAlert rdf:resource="http://example.org/logistics#Item_SulfuricAcid_TransportHazardAlert"/>
    <logistics:isHazardous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</logistics:isHazardous>
    <logistics:itemName>Industrial Sulfuric Acid</logistics:itemName>
    <logistics:managedBy rdf:resource="http://example.org/logistics#Officer_Bob"/>
    <logistics:minThreshold rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">80</logistics:minThreshold>
    <logistics:quantity rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">150</logistics:quantity>
    <logistics:requiresCooling rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</logistics:requiresCooling>
    <logistics:storedIn rdf:resource="http://example.org/logistics#Warehouse_A"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/logistics#HazardousItem">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Hazardous Item</rdfs:label>
    <rdfs:comment>Stock item containing dangerous or chemical goods.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://example.org/logistics#StockItem"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/logistics#quantity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>quantity</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/logistics#StockItem"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/logistics#Warehouse_A_CapacityAlert">
    <rdf:type rdf:resource="http://example.org/logistics#CapacityAlert"/>
    <logistics:alertMessage rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Capacity exceeded at 'Main Warehouse A': storing 1220 items (limit is 1000).</logistics:alertMessage>
    <logistics:alertSeverity rdf:datatype="http://www.w3.org/2001/XMLSchema#string">High</logistics:alertSeverity>
    <logistics:alertType rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Capacity Limit Exceeded</logistics:alertType>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/logistics#hasCooling">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>has cooling</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/logistics#StorageFacility"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/logistics#alertMessage">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>alert message</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/logistics#Alert"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/logistics#Truck_Haz">
    <rdf:type rdf:resource="http://example.org/logistics#ChemicalTanker"/>
    <rdf:type rdf:resource="http://example.org/logistics#Entity"/>
    <rdf:type rdf:resource="http://example.org/logistics#TransportVehicle"/>
    <logistics:hasHazardousPermit rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</logistics:hasHazardousPermit>
    <logistics:hasVehicleCooling rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</logistics:hasVehicleCooling>
    <logistics:vehicleName>HazMat Cargo Tanker (T-30)</logistics:vehicleName>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/logistics#FlatbedTruck">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Flatbed Truck</rdfs:label>
    <rdfs:comment>Standard open-box transport vehicle.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://example.org/logistics#TransportVehicle"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/logistics#Item_LiquidNitrogen">
    <rdf:type rdf:resource="http://example.org/logistics#Entity"/>
    <rdf:type rdf:resource="http://example.org/logistics#HazardousItem"/>
    <rdf:type rdf:resource="http://example.org/logistics#StockItem"/>
    <logistics:assignedTo rdf:resource="http://example.org/logistics#Truck_Haz"/>
    <logistics:hasAlert rdf:resource="http://example.org/logistics#Item_LiquidNitrogen_LowStockAlert"/>
    <logistics:isHazardous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</logistics:isHazardous>
    <logistics:itemName>Liquid Nitrogen Cylinder</logistics:itemName>
    <logistics:managedBy rdf:resource="http://example.org/logistics#Officer_Bob"/>
    <logistics:minThreshold rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">100</logistics:minThreshold>
    <logistics:quantity rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">80</logistics:quantity>
    <logistics:requiresCooling rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</logistics:requiresCooling>
    <logistics:storedIn rdf:resource="http://example.org/logistics#HazMat_Depot"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/logistics#LowStockAlert">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Low Stock Alert</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/logistics#Alert"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/logistics#itemName">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>item name</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/logistics#StockItem"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/logistics#alertType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>alert type</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/logistics#Alert"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/logistics#PerishableItem">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Perishable Item</rdfs:label>
    <rdfs:comment>Stock item requiring temperature-controlled storage.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://example.org/logistics#StockItem"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/logistics#RefrigeratedTruck">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Refrigerated Truck</rdfs:label>
    <rdfs:comment>Vehicle with built-in cargo refrigeration.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://example.org/logistics#TransportVehicle"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/logistics#hasAlert">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>has alert</rdfs:label>
    <rdfs:comment>Associates an entity with an inferred compliance warning or alert.</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/logistics#Entity"/>
    <rdfs:range rdf:resource="http://example.org/logistics#Alert"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/logistics#Item_FreshMilk">
    <rdf:type rdf:resource="http://example.org/logistics#Entity"/>
    <rdf:type rdf:resource="http://example.org/logistics#PerishableItem"/>
    <rdf:type rdf:resource="http://example.org/logistics#StockItem"/>
    <logistics:assignedTo rdf:resource="http://example.org/logistics#Truck_Cool"/>
    <logistics:isHazardous rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</logistics:isHazardous>
    <logistics:itemName>Fresh Dairy Milk</logistics:itemName>
    <logistics:managedBy rdf:resource="http://example.org/logistics#Officer_Alice"/>
    <logistics:minThreshold rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">150</logistics:minThreshold>
    <logistics:quantity rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">200</logistics:quantity>
    <logistics:requiresCooling rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</logistics:requiresCooling>
    <logistics:storedIn rdf:resource="http://example.org/logistics#ColdHub_1"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/logistics#Item_FrozenFish_TransportCoolingAlert">
    <rdf:type rdf:resource="http://example.org/logistics#TransportConflictAlert"/>
    <logistics:alertMessage rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Perishable item 'Frozen Salmon Filets' requires refrigerated transport, but is assigned to 'Flatbed Truck (T-10)' which lacks cooling.</logistics:alertMessage>
    <logistics:alertSeverity rdf:datatype="http://www.w3.org/2001/XMLSchema#string">High</logistics:alertSeverity>
    <logistics:alertType rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Transport Cooling Conflict</logistics:alertType>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/logistics#capacity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>capacity</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/logistics#StorageFacility"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/logistics#Officer_Bob">
    <rdf:type rdf:resource="http://example.org/logistics#Entity"/>
    <rdf:type rdf:resource="http://example.org/logistics#ProcurementOfficer"/>
    <logistics:officerName>Bob Smith</logistics:officerName>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/logistics#ColdStorage">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Cold Storage Facility</rdfs:label>
    <rdfs:comment>Warehouse equipped with refrigeration controls.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://example.org/logistics#StorageFacility"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/logistics#Warehouse_A">
    <rdf:type rdf:resource="http://example.org/logistics#Entity"/>
    <rdf:type rdf:resource="http://example.org/logistics#GeneralStorage"/>
    <rdf:type rdf:resource="http://example.org/logistics#StorageFacility"/>
    <logistics:capacity rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1000</logistics:capacity>
    <logistics:facilityName>Main Warehouse A</logistics:facilityName>
    <logistics:hasAlert rdf:resource="http://example.org/logistics#Item_FrozenFish_StorageCoolingAlert"/>
    <logistics:hasAlert rdf:resource="http://example.org/logistics#Item_SulfuricAcid_StorageHazardAlert"/>
    <logistics:hasAlert rdf:resource="http://example.org/logistics#Warehouse_A_CapacityAlert"/>
    <logistics:hasCooling rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</logistics:hasCooling>
    <logistics:isHazardousApproved rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</logistics:isHazardousApproved>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/logistics#ChemicalTanker">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Chemical Tanker</rdfs:label>
    <rdfs:comment>Vehicle certified to transport hazardous materials.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://example.org/logistics#TransportVehicle"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/logistics#TransportConflictAlert">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Transport Conflict Alert</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/logistics#Alert"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/logistics#Truck_Cool">
    <rdf:type rdf:resource="http://example.org/logistics#Entity"/>
    <rdf:type rdf:resource="http://example.org/logistics#RefrigeratedTruck"/>
    <rdf:type rdf:resource="http://example.org/logistics#TransportVehicle"/>
    <logistics:hasHazardousPermit rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</logistics:hasHazardousPermit>
    <logistics:hasVehicleCooling rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</logistics:hasVehicleCooling>
    <logistics:vehicleName>ThermoKing Refrigerated (T-20)</logistics:vehicleName>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/logistics#CapacityAlert">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Capacity Alert</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/logistics#Alert"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/logistics#Alert">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Alert</rdfs:label>
    <rdfs:comment>Represents a reasoning conflict, constraint violation, or low stock warning.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://example.org/logistics#Entity"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/logistics#hasVehicleCooling">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>has vehicle cooling</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/logistics#TransportVehicle"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/logistics#hasHazardousPermit">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>has hazardous permit</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/logistics#TransportVehicle"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/logistics#Truck_Standard">
    <rdf:type rdf:resource="http://example.org/logistics#Entity"/>
    <rdf:type rdf:resource="http://example.org/logistics#FlatbedTruck"/>
    <rdf:type rdf:resource="http://example.org/logistics#TransportVehicle"/>
    <logistics:hasAlert rdf:resource="http://example.org/logistics#Item_FrozenFish_TransportCoolingAlert"/>
    <logistics:hasAlert rdf:resource="http://example.org/logistics#Item_SulfuricAcid_TransportHazardAlert"/>
    <logistics:hasHazardousPermit rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</logistics:hasHazardousPermit>
    <logistics:hasVehicleCooling rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</logistics:hasVehicleCooling>
    <logistics:vehicleName>Flatbed Truck (T-10)</logistics:vehicleName>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/logistics#isHazardousApproved">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>is hazardous approved</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/logistics#StorageFacility"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/logistics#storedIn">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>stored in</rdfs:label>
    <rdfs:comment>Indicates which warehouse facility holds the stock item.</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/logistics#StockItem"/>
    <rdfs:range rdf:resource="http://example.org/logistics#StorageFacility"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/logistics#assignedTo">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>assigned to</rdfs:label>
    <rdfs:comment>Indicates which transport vehicle is assigned to move the item.</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/logistics#StockItem"/>
    <rdfs:range rdf:resource="http://example.org/logistics#TransportVehicle"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/logistics#Item_LiquidNitrogen_LowStockAlert">
    <rdf:type rdf:resource="http://example.org/logistics#LowStockAlert"/>
    <logistics:alertMessage rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Stock level for 'Liquid Nitrogen Cylinder' is low: 80 remaining (minimum threshold is 100).</logistics:alertMessage>
    <logistics:alertSeverity rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Medium</logistics:alertSeverity>
    <logistics:alertType rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Low Stock</logistics:alertType>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/logistics#managedBy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>managed by</rdfs:label>
    <rdfs:comment>Indicates the procurement officer responsible for this inventory item.</rdfs:comment>
    <rdfs:domain rdf:resource="http://example.org/logistics#StockItem"/>
    <rdfs:range rdf:resource="http://example.org/logistics#ProcurementOfficer"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/logistics#officerName">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>officer name</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/logistics#ProcurementOfficer"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/logistics#Item_SulfuricAcid_TransportHazardAlert">
    <rdf:type rdf:resource="http://example.org/logistics#TransportConflictAlert"/>
    <logistics:alertMessage rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hazardous item 'Industrial Sulfuric Acid' requires specialized vehicle transit, but is assigned to 'Flatbed Truck (T-10)' which lacks a hazardous permit.</logistics:alertMessage>
    <logistics:alertSeverity rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Critical</logistics:alertSeverity>
    <logistics:alertType rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Transport Hazard Conflict</logistics:alertType>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/logistics#Item_FrozenFish_StorageCoolingAlert">
    <rdf:type rdf:resource="http://example.org/logistics#StorageConflictAlert"/>
    <logistics:alertMessage rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Perishable item 'Frozen Salmon Filets' requires cold storage, but is stored in 'Main Warehouse A' which lacks cooling.</logistics:alertMessage>
    <logistics:alertSeverity rdf:datatype="http://www.w3.org/2001/XMLSchema#string">High</logistics:alertSeverity>
    <logistics:alertType rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Storage Cooling Conflict</logistics:alertType>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/logistics#minThreshold">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>minimum threshold</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/logistics#StockItem"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/logistics#facilityName">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>facility name</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/logistics#StorageFacility"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/logistics#StorageFacility">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Storage Facility</rdfs:label>
    <rdfs:comment>A location where stock items are kept.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://example.org/logistics#Entity"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/logistics#TransportVehicle">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Transport Vehicle</rdfs:label>
    <rdfs:comment>Vehicles used to transport stock items.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://example.org/logistics#Entity"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/logistics#HazardousStorage">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Hazardous Storage Facility</rdfs:label>
    <rdfs:comment>Warehouse approved to hold chemical/dangerous materials safely.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://example.org/logistics#StorageFacility"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/logistics#StorageConflictAlert">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Storage Conflict Alert</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://example.org/logistics#Alert"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/logistics#alertSeverity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>alert severity</rdfs:label>
    <rdfs:domain rdf:resource="http://example.org/logistics#Alert"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/logistics">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
    <rdfs:label>Inventory Management Knowledge System Ontology</rdfs:label>
    <rdfs:comment>An ontology for managing stock items, warehouses, vehicles, officers, and automated compliance reasoning.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="http://example.org/logistics#Entity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Entity</rdfs:label>
    <rdfs:comment>Root class for all domain concepts in the IMKS.</rdfs:comment>
  </rdf:Description>
</rdf:RDF>
