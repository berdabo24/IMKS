@prefix logistics: <http://example.org/logistics#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/logistics> a owl:Ontology ;
    rdfs:label "Inventory Management Knowledge System Ontology" ;
    rdfs:comment "An ontology for managing stock items, warehouses, vehicles, officers, and automated compliance reasoning." .

logistics:Item_CardboardBoxes a logistics:Entity,
        logistics:StandardItem,
        logistics:StockItem ;
    logistics:assignedTo logistics:Truck_Standard ;
    logistics:isHazardous false ;
    logistics:itemName "Cardboard Packing Boxes" ;
    logistics:managedBy logistics:Officer_Alice ;
    logistics:minThreshold 200 ;
    logistics:quantity 950 ;
    logistics:requiresCooling false ;
    logistics:storedIn logistics:Warehouse_A .

logistics:Item_FreshMilk a logistics:Entity,
        logistics:PerishableItem,
        logistics:StockItem ;
    logistics:assignedTo logistics:Truck_Cool ;
    logistics:isHazardous false ;
    logistics:itemName "Fresh Dairy Milk" ;
    logistics:managedBy logistics:Officer_Alice ;
    logistics:minThreshold 150 ;
    logistics:quantity 200 ;
    logistics:requiresCooling true ;
    logistics:storedIn logistics:ColdHub_1 .

logistics:Item_FrozenFish a logistics:Entity,
        logistics:PerishableItem,
        logistics:StockItem ;
    logistics:assignedTo logistics:Truck_Standard ;
    logistics:hasAlert logistics:Item_FrozenFish_StorageCoolingAlert,
        logistics:Item_FrozenFish_TransportCoolingAlert ;
    logistics:isHazardous false ;
    logistics:itemName "Frozen Salmon Filets" ;
    logistics:managedBy logistics:Officer_Alice ;
    logistics:minThreshold 50 ;
    logistics:quantity 120 ;
    logistics:requiresCooling true ;
    logistics:storedIn logistics:Warehouse_A .

logistics:Item_LiquidNitrogen a logistics:Entity,
        logistics:HazardousItem,
        logistics:StockItem ;
    logistics:assignedTo logistics:Truck_Haz ;
    logistics:hasAlert logistics:Item_LiquidNitrogen_LowStockAlert ;
    logistics:isHazardous true ;
    logistics:itemName "Liquid Nitrogen Cylinder" ;
    logistics:managedBy logistics:Officer_Bob ;
    logistics:minThreshold 100 ;
    logistics:quantity 80 ;
    logistics:requiresCooling false ;
    logistics:storedIn logistics:HazMat_Depot .

logistics:Item_SulfuricAcid a logistics:Entity,
        logistics:HazardousItem,
        logistics:StockItem ;
    logistics:assignedTo logistics:Truck_Standard ;
    logistics:hasAlert logistics:Item_SulfuricAcid_StorageHazardAlert,
        logistics:Item_SulfuricAcid_TransportHazardAlert ;
    logistics:isHazardous true ;
    logistics:itemName "Industrial Sulfuric Acid" ;
    logistics:managedBy logistics:Officer_Bob ;
    logistics:minThreshold 80 ;
    logistics:quantity 150 ;
    logistics:requiresCooling false ;
    logistics:storedIn logistics:Warehouse_A .

logistics:alertMessage a owl:DatatypeProperty ;
    rdfs:label "alert message" ;
    rdfs:domain logistics:Alert ;
    rdfs:range xsd:string .

logistics:alertSeverity a owl:DatatypeProperty ;
    rdfs:label "alert severity" ;
    rdfs:domain logistics:Alert ;
    rdfs:range xsd:string .

logistics:alertType a owl:DatatypeProperty ;
    rdfs:label "alert type" ;
    rdfs:domain logistics:Alert ;
    rdfs:range xsd:string .

logistics:assignedTo a owl:ObjectProperty ;
    rdfs:label "assigned to" ;
    rdfs:comment "Indicates which transport vehicle is assigned to move the item." ;
    rdfs:domain logistics:StockItem ;
    rdfs:range logistics:TransportVehicle .

logistics:capacity a owl:DatatypeProperty ;
    rdfs:label "capacity" ;
    rdfs:domain logistics:StorageFacility ;
    rdfs:range xsd:integer .

logistics:facilityName a owl:DatatypeProperty ;
    rdfs:label "facility name" ;
    rdfs:domain logistics:StorageFacility ;
    rdfs:range xsd:string .

logistics:hasAlert a owl:ObjectProperty ;
    rdfs:label "has alert" ;
    rdfs:comment "Associates an entity with an inferred compliance warning or alert." ;
    rdfs:domain logistics:Entity ;
    rdfs:range logistics:Alert .

logistics:hasCooling a owl:DatatypeProperty ;
    rdfs:label "has cooling" ;
    rdfs:domain logistics:StorageFacility ;
    rdfs:range xsd:boolean .

logistics:hasHazardousPermit a owl:DatatypeProperty ;
    rdfs:label "has hazardous permit" ;
    rdfs:domain logistics:TransportVehicle ;
    rdfs:range xsd:boolean .

logistics:hasVehicleCooling a owl:DatatypeProperty ;
    rdfs:label "has vehicle cooling" ;
    rdfs:domain logistics:TransportVehicle ;
    rdfs:range xsd:boolean .

logistics:isHazardous a owl:DatatypeProperty ;
    rdfs:label "is hazardous" ;
    rdfs:domain logistics:StockItem ;
    rdfs:range xsd:boolean .

logistics:isHazardousApproved a owl:DatatypeProperty ;
    rdfs:label "is hazardous approved" ;
    rdfs:domain logistics:StorageFacility ;
    rdfs:range xsd:boolean .

logistics:itemName a owl:DatatypeProperty ;
    rdfs:label "item name" ;
    rdfs:domain logistics:StockItem ;
    rdfs:range xsd:string .

logistics:managedBy a owl:ObjectProperty ;
    rdfs:label "managed by" ;
    rdfs:comment "Indicates the procurement officer responsible for this inventory item." ;
    rdfs:domain logistics:StockItem ;
    rdfs:range logistics:ProcurementOfficer .

logistics:minThreshold a owl:DatatypeProperty ;
    rdfs:label "minimum threshold" ;
    rdfs:domain logistics:StockItem ;
    rdfs:range xsd:integer .

logistics:officerName a owl:DatatypeProperty ;
    rdfs:label "officer name" ;
    rdfs:domain logistics:ProcurementOfficer ;
    rdfs:range xsd:string .

logistics:quantity a owl:DatatypeProperty ;
    rdfs:label "quantity" ;
    rdfs:domain logistics:StockItem ;
    rdfs:range xsd:integer .

logistics:requiresCooling a owl:DatatypeProperty ;
    rdfs:label "requires cooling" ;
    rdfs:domain logistics:StockItem ;
    rdfs:range xsd:boolean .

logistics:storedIn a owl:ObjectProperty ;
    rdfs:label "stored in" ;
    rdfs:comment "Indicates which warehouse facility holds the stock item." ;
    rdfs:domain logistics:StockItem ;
    rdfs:range logistics:StorageFacility .

logistics:vehicleName a owl:DatatypeProperty ;
    rdfs:label "vehicle name" ;
    rdfs:domain logistics:TransportVehicle ;
    rdfs:range xsd:string .

logistics:CapacityAlert a owl:Class ;
    rdfs:label "Capacity Alert" ;
    rdfs:subClassOf logistics:Alert .

logistics:ChemicalTanker a owl:Class ;
    rdfs:label "Chemical Tanker" ;
    rdfs:comment "Vehicle certified to transport hazardous materials." ;
    rdfs:subClassOf logistics:TransportVehicle .

logistics:ColdHub_1 a logistics:ColdStorage,
        logistics:Entity,
        logistics:StorageFacility ;
    logistics:capacity 500 ;
    logistics:facilityName "Refrigerated ColdHub 1" ;
    logistics:hasCooling true ;
    logistics:isHazardousApproved false .

logistics:ColdStorage a owl:Class ;
    rdfs:label "Cold Storage Facility" ;
    rdfs:comment "Warehouse equipped with refrigeration controls." ;
    rdfs:subClassOf logistics:StorageFacility .

logistics:FlatbedTruck a owl:Class ;
    rdfs:label "Flatbed Truck" ;
    rdfs:comment "Standard open-box transport vehicle." ;
    rdfs:subClassOf logistics:TransportVehicle .

logistics:GeneralStorage a owl:Class ;
    rdfs:label "General Storage Facility" ;
    rdfs:comment "Standard ambient warehouse." ;
    rdfs:subClassOf logistics:StorageFacility .

logistics:HazMat_Depot a logistics:Entity,
        logistics:HazardousStorage,
        logistics:StorageFacility ;
    logistics:capacity 300 ;
    logistics:facilityName "Secured Chemical Depot" ;
    logistics:hasCooling false ;
    logistics:isHazardousApproved true .

logistics:HazardousStorage a owl:Class ;
    rdfs:label "Hazardous Storage Facility" ;
    rdfs:comment "Warehouse approved to hold chemical/dangerous materials safely." ;
    rdfs:subClassOf logistics:StorageFacility .

logistics:Item_LiquidNitrogen_LowStockAlert a logistics:LowStockAlert ;
    logistics:alertMessage "Stock level for 'Liquid Nitrogen Cylinder' is low: 80 remaining (minimum threshold is 100)."^^xsd:string ;
    logistics:alertSeverity "Medium"^^xsd:string ;
    logistics:alertType "Low Stock"^^xsd:string .

logistics:LowStockAlert a owl:Class ;
    rdfs:label "Low Stock Alert" ;
    rdfs:subClassOf logistics:Alert .

logistics:RefrigeratedTruck a owl:Class ;
    rdfs:label "Refrigerated Truck" ;
    rdfs:comment "Vehicle with built-in cargo refrigeration." ;
    rdfs:subClassOf logistics:TransportVehicle .

logistics:StandardItem a owl:Class ;
    rdfs:label "Standard Item" ;
    rdfs:comment "Regular stock item requiring no specialized conditions." ;
    rdfs:subClassOf logistics:StockItem .

logistics:Truck_Cool a logistics:Entity,
        logistics:RefrigeratedTruck,
        logistics:TransportVehicle ;
    logistics:hasHazardousPermit false ;
    logistics:hasVehicleCooling true ;
    logistics:vehicleName "ThermoKing Refrigerated (T-20)" .

logistics:Truck_Haz a logistics:ChemicalTanker,
        logistics:Entity,
        logistics:TransportVehicle ;
    logistics:hasHazardousPermit true ;
    logistics:hasVehicleCooling false ;
    logistics:vehicleName "HazMat Cargo Tanker (T-30)" .

logistics:Warehouse_A_CapacityAlert a logistics:CapacityAlert ;
    logistics:alertMessage "Capacity exceeded at 'Main Warehouse A': storing 1220 items (limit is 1000)."^^xsd:string ;
    logistics:alertSeverity "High"^^xsd:string ;
    logistics:alertType "Capacity Limit Exceeded"^^xsd:string .

logistics:HazardousItem a owl:Class ;
    rdfs:label "Hazardous Item" ;
    rdfs:comment "Stock item containing dangerous or chemical goods." ;
    rdfs:subClassOf logistics:StockItem .

logistics:Item_FrozenFish_StorageCoolingAlert a logistics:StorageConflictAlert ;
    logistics:alertMessage "Perishable item 'Frozen Salmon Filets' requires cold storage, but is stored in 'Main Warehouse A' which lacks cooling."^^xsd:string ;
    logistics:alertSeverity "High"^^xsd:string ;
    logistics:alertType "Storage Cooling Conflict"^^xsd:string .

logistics:Item_FrozenFish_TransportCoolingAlert a logistics:TransportConflictAlert ;
    logistics:alertMessage "Perishable item 'Frozen Salmon Filets' requires refrigerated transport, but is assigned to 'Flatbed Truck (T-10)' which lacks cooling."^^xsd:string ;
    logistics:alertSeverity "High"^^xsd:string ;
    logistics:alertType "Transport Cooling Conflict"^^xsd:string .

logistics:Item_SulfuricAcid_StorageHazardAlert a logistics:StorageConflictAlert ;
    logistics:alertMessage "Hazardous item 'Industrial Sulfuric Acid' is stored in 'Main Warehouse A', which is not approved for hazardous materials."^^xsd:string ;
    logistics:alertSeverity "Critical"^^xsd:string ;
    logistics:alertType "Hazardous Storage Conflict"^^xsd:string .

logistics:Item_SulfuricAcid_TransportHazardAlert a logistics:TransportConflictAlert ;
    logistics:alertMessage "Hazardous item 'Industrial Sulfuric Acid' requires specialized vehicle transit, but is assigned to 'Flatbed Truck (T-10)' which lacks a hazardous permit."^^xsd:string ;
    logistics:alertSeverity "Critical"^^xsd:string ;
    logistics:alertType "Transport Hazard Conflict"^^xsd:string .

logistics:Officer_Bob a logistics:Entity,
        logistics:ProcurementOfficer ;
    logistics:officerName "Bob Smith" .

logistics:PerishableItem a owl:Class ;
    rdfs:label "Perishable Item" ;
    rdfs:comment "Stock item requiring temperature-controlled storage." ;
    rdfs:subClassOf logistics:StockItem .

logistics:StorageConflictAlert a owl:Class ;
    rdfs:label "Storage Conflict Alert" ;
    rdfs:subClassOf logistics:Alert .

logistics:TransportConflictAlert a owl:Class ;
    rdfs:label "Transport Conflict Alert" ;
    rdfs:subClassOf logistics:Alert .

logistics:Officer_Alice a logistics:Entity,
        logistics:ProcurementOfficer ;
    logistics:officerName "Alice Johnson" .

logistics:Truck_Standard a logistics:Entity,
        logistics:FlatbedTruck,
        logistics:TransportVehicle ;
    logistics:hasAlert logistics:Item_FrozenFish_TransportCoolingAlert,
        logistics:Item_SulfuricAcid_TransportHazardAlert ;
    logistics:hasHazardousPermit false ;
    logistics:hasVehicleCooling false ;
    logistics:vehicleName "Flatbed Truck (T-10)" .

logistics:Warehouse_A a logistics:Entity,
        logistics:GeneralStorage,
        logistics:StorageFacility ;
    logistics:capacity 1000 ;
    logistics:facilityName "Main Warehouse A" ;
    logistics:hasAlert logistics:Item_FrozenFish_StorageCoolingAlert,
        logistics:Item_SulfuricAcid_StorageHazardAlert,
        logistics:Warehouse_A_CapacityAlert ;
    logistics:hasCooling false ;
    logistics:isHazardousApproved false .

logistics:ProcurementOfficer a owl:Class ;
    rdfs:label "Procurement Officer" ;
    rdfs:comment "Personnel responsible for managing stock inventory and alerts." ;
    rdfs:subClassOf logistics:Entity .

logistics:Alert a owl:Class ;
    rdfs:label "Alert" ;
    rdfs:comment "Represents a reasoning conflict, constraint violation, or low stock warning." ;
    rdfs:subClassOf logistics:Entity .

logistics:TransportVehicle a owl:Class ;
    rdfs:label "Transport Vehicle" ;
    rdfs:comment "Vehicles used to transport stock items." ;
    rdfs:subClassOf logistics:Entity .

logistics:StorageFacility a owl:Class ;
    rdfs:label "Storage Facility" ;
    rdfs:comment "A location where stock items are kept." ;
    rdfs:subClassOf logistics:Entity .

logistics:StockItem a owl:Class ;
    rdfs:label "Stock Item" ;
    rdfs:comment "A product or inventory item stored in warehouses." ;
    rdfs:subClassOf logistics:Entity .

logistics:Entity a owl:Class ;
    rdfs:label "Entity" ;
    rdfs:comment "Root class for all domain concepts in the IMKS." .

